source "https://rubygems.org"

gem "jekyll-theme-chirpy", "~> 7.0"

# Jekyll auto-requires gems in this group. Used for redirects when a published
# note is renamed (its URL changes) — the sync injects `redirect_from`.
group :jekyll_plugins do
  gem "jekyll-redirect-from", "~> 0.16"
end

group :test do
  gem "html-proofer", "~> 5.0"
end
