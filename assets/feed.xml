---
layout: compress
permalink: /feed.xml
# Atom feed — local override of the theme's: full post content inline, all posts.
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <id>{{ '/' | absolute_url }}</id>
  <title>{{ site.title | xml_escape }}</title>
  <subtitle>{{ site.description | xml_escape }}</subtitle>
  <updated>{{ site.time | date_to_xmlschema }}</updated>
  <author>
    <name>{{ site.social.name | xml_escape }}</name>
    <uri>{{ '/' | absolute_url }}</uri>
  </author>
  <link rel="self" type="application/atom+xml" href="{{ page.url | absolute_url }}"/>
  <link rel="alternate" type="text/html" href="{{ '/' | absolute_url }}"/>
  <generator uri="https://jekyllrb.com/" version="{{ jekyll.version }}">Jekyll</generator>
  <rights>© {{ 'now' | date: '%Y' }} {{ site.social.name | xml_escape }}</rights>
  <icon>{{ '/assets/img/favicons/favicon.ico' | absolute_url }}</icon>
  <logo>{{ '/assets/img/favicons/favicon-96x96.png' | absolute_url }}</logo>
{% for post in site.posts limit: 30 %}
  {% assign post_url = post.url | absolute_url %}
  {% capture summary %}{% include post-summary.html max_length=400 %}{% endcapture %}
  <entry>
    <title>{{ post.title | xml_escape }}</title>
    <link href="{{ post_url }}" rel="alternate" type="text/html" title="{{ post.title | xml_escape }}"/>
    <published>{{ post.date | date_to_xmlschema }}</published>
    <updated>{{ post.last_modified_at | default: post.date | date_to_xmlschema }}</updated>
    <id>{{ post_url }}</id>
    <author><name>{{ post.author | default: site.social.name | xml_escape }}</name></author>
{% if post.categories %}{% for category in post.categories %}    <category term="{{ category | xml_escape }}"/>
{% endfor %}{% endif %}    <summary>{{ summary | strip | xml_escape }}</summary>
    <content type="html">{{ post.content | feed_content: post_url | xml_escape }}</content>
  </entry>
{% endfor %}
</feed>
